NODE_ENV=development
PORT=3000
API_VERSION=v1
FRONTEND_DIST_DIR=../frontend/dist
LOG_LEVEL=debug

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/edutech_platform?schema=public"

JWT_SECRET="replace-with-at-least-32-characters-secret"
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET="replace-with-a-different-32-characters-secret"
JWT_REFRESH_EXPIRES_IN=30d

PASSWORD_RESET_CODE_TTL_MINUTES=15
PASSWORD_RESET_MAX_ATTEMPTS=5
PASSWORD_RESET_TOKEN_EXPIRES_IN=15m
AUTH_MAX_FAILED_LOGINS=5
AUTH_LOCKOUT_MINUTES=15

PLATFORM_COMMISSION_RATE=10
MAX_FILE_SIZE=524288000
UPLOAD_DIR=uploads

CORS_ORIGIN=http://localhost:5173
SOCKET_CORS_ORIGIN=http://localhost:5173

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
